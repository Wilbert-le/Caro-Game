<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %> · Five in a Row</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600;700&family=Inter:wght@300;400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/main.css" />
</head>
<body>

<div class="home-wrapper">

  <!-- Decorative dots -->
  <div class="dots-row" aria-hidden="true">
    <span class="dot dot--purple"></span>
    <span class="dot dot--blue"></span>
    <span class="dot dot--green"></span>
    <span class="dot dot--orange"></span>
    <span class="dot dot--red"></span>
  </div>

  <!-- Logo -->
  <header class="home-header">
    <h1 class="logo">CARO</h1>
    <p class="tagline">FIVE IN A ROW &nbsp;·&nbsp; GOMOKU</p>
  </header>

  <!-- Menu cards -->
  <main class="menu">

    <!-- 2 Players -->
    <a href="#" class="menu-card" id="btn-2players" role="button" aria-label="2 Players - Local face-off on one device">
      <div class="menu-card__icon menu-card__icon--blue">
        <!-- Two-person icon -->
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="9" cy="7" r="3"/>
          <path d="M3 21v-2a4 4 0 0 1 4-4h4a4 4 0 0 1 4 4v2"/>
          <circle cx="18" cy="7" r="2.5" opacity="0.6"/>
          <path d="M21 21v-1.5a3.5 3.5 0 0 0-2-3.17" opacity="0.6"/>
        </svg>
      </div>
      <div class="menu-card__text">
        <span class="menu-card__title">2 Players</span>
        <span class="menu-card__desc">Local face-off on one device</span>
      </div>
      <div class="menu-card__arrow" aria-hidden="true">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M9 18l6-6-6-6"/>
        </svg>
      </div>
    </a>

    <!-- vs AI -->
    <a href="#" class="menu-card" id="btn-vsai" role="button" aria-label="vs AI - Challenge the machine">
      <div class="menu-card__icon menu-card__icon--purple">
        <!-- Brain icon -->
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 5a3 3 0 1 0-5.997.125 4 4 0 0 0-2.526 5.77 4 4 0 0 0 .556 6.588A4 4 0 1 0 12 18Z"/>
          <path d="M12 5a3 3 0 1 1 5.997.125 4 4 0 0 1 2.526 5.77 4 4 0 0 1-.556 6.588A4 4 0 1 1 12 18Z"/>
          <path d="M15 13a4.5 4.5 0 0 1-3-4 4.5 4.5 0 0 1-3 4"/>
          <path d="M17.599 6.5a3 3 0 0 0 .399-1.375"/>
          <path d="M6.003 5.125A3 3 0 0 0 6.401 6.5"/>
          <path d="M3.477 10.896a4 4 0 0 1 .585-.396"/>
          <path d="M19.938 10.5a4 4 0 0 1 .585.396"/>
          <path d="M6 18a4 4 0 0 1-1.967-.516"/>
          <path d="M19.967 17.484A4 4 0 0 1 18 18"/>
        </svg>
      </div>
      <div class="menu-card__text">
        <span class="menu-card__title">vs AI</span>
        <span class="menu-card__desc">Challenge the machine</span>
      </div>
      <div class="menu-card__arrow" aria-hidden="true">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M9 18l6-6-6-6"/>
        </svg>
      </div>
    </a>

  </main>

  <!-- Footer hint -->
  <footer class="home-footer">
    <p class="footer-hint">PLACE 5 IN A ROW TO WIN</p>
  </footer>

  <!-- Help button -->
  <button class="help-btn" id="btn-help" aria-label="Help">?</button>

</div>

<!-- Modal: chọn tên người chơi (2 Players) -->
<div class="modal-overlay" id="modal-local" role="dialog" aria-modal="true" aria-labelledby="modal-local-title">
  <div class="modal">
    <h2 class="modal__title" id="modal-local-title">2 Players</h2>
    <p class="modal__sub">Enter player names</p>
    <div class="modal__field">
      <label for="input-p1">Player 1 (X)</label>
      <input type="text" id="input-p1" placeholder="Player 1" maxlength="20" autocomplete="off" />
    </div>
    <div class="modal__field">
      <label for="input-p2">Player 2 (O)</label>
      <input type="text" id="input-p2" placeholder="Player 2" maxlength="20" autocomplete="off" />
    </div>
    <div class="modal__actions">
      <button class="btn btn--ghost" id="modal-local-cancel">Cancel</button>
      <button class="btn btn--primary" id="modal-local-start">Start Game</button>
    </div>
  </div>
</div>

<!-- Setup screen: vs AI (full page) -->
<div class="setup-screen" id="setup-ai" aria-hidden="true">
  <div class="setup-inner">

    <div class="setup-header">
      <p class="setup-label">GAME SETUP</p>
      <h2 class="setup-title">vs AI</h2>
    </div>

    <!-- Difficulty -->
    <section class="setup-section">
      <p class="setup-section-label">DIFFICULTY</p>
      <div class="diff-cards" id="diff-cards">

        <button class="diff-card active" data-level="easy" aria-pressed="true">
          <span class="diff-card__icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"/><path d="M8 14s1.5 2 4 2 4-2 4-2"/><line x1="9" y1="9" x2="9.01" y2="9"/><line x1="15" y1="9" x2="15.01" y2="9"/>
            </svg>
          </span>
          <span class="diff-card__text">
            <span class="diff-card__name">Easy</span>
            <span class="diff-card__desc">AI plays casually</span>
          </span>
          <span class="diff-card__check" aria-hidden="true">✓</span>
        </button>

        <button class="diff-card" data-level="medium" aria-pressed="false">
          <span class="diff-card__icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>
            </svg>
          </span>
          <span class="diff-card__text">
            <span class="diff-card__name">Medium</span>
            <span class="diff-card__desc">AI blocks &amp; counterattacks</span>
          </span>
          <span class="diff-card__check" aria-hidden="true">✓</span>
        </button>

        <button class="diff-card" data-level="hard" aria-pressed="false">
          <span class="diff-card__icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
            </svg>
          </span>
          <span class="diff-card__text">
            <span class="diff-card__name">Hard</span>
            <span class="diff-card__desc">AI thinks ahead — good luck</span>
          </span>
          <span class="diff-card__check" aria-hidden="true">✓</span>
        </button>

      </div>
    </section>

    <!-- You play as -->
    <section class="setup-section">
      <p class="setup-section-label">YOU PLAY AS</p>
      <div class="order-cards" id="order-cards">

        <button class="order-card active" data-order="first" aria-pressed="true">
          <span class="order-card__stone order-card__stone--black"></span>
          <span class="order-card__name">First</span>
          <span class="order-card__desc">Black — you start</span>
        </button>

        <button class="order-card" data-order="second" aria-pressed="false">
          <span class="order-card__stone order-card__stone--white"></span>
          <span class="order-card__name">Second</span>
          <span class="order-card__desc">White — AI starts</span>
        </button>

      </div>
    </section>

    <!-- Actions -->
    <div class="setup-actions">
      <button class="btn btn--ghost setup-back" id="setup-ai-back">← Back</button>
      <button class="btn btn--play" id="setup-ai-start">PLAY</button>
    </div>

  </div>
</div>

<!-- Modal: Hướng dẫn -->
<div class="modal-overlay" id="modal-help" role="dialog" aria-modal="true" aria-labelledby="modal-help-title">
  <div class="modal modal--help">
    <h2 class="modal__title" id="modal-help-title">How to Play</h2>
    <ul class="help-list">
      <li><span class="help-num">01</span><span>Players take turns placing their piece (X or O) on the board.</span></li>
      <li><span class="help-num">02</span><span>The first player to get <strong>5 in a row</strong> wins — horizontally, vertically, or diagonally.</span></li>
      <li><span class="help-num">03</span><span>A row blocked on both ends doesn't count as a winning move.</span></li>
    </ul>
    <div class="modal__actions">
      <button class="btn btn--primary" id="modal-help-close">Got it</button>
    </div>
  </div>
</div>

<script src="/js/home.js"></script>
</body>
</html>
